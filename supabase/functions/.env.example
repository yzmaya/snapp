# ============================================================
# SECRETOS de las Edge Functions (NO son variables del frontend)
# Se configuran en Supabase, no en el navegador.
# ============================================================
# Cárgalos con la CLI (recomendado):
#   supabase secrets set --env-file supabase/functions/.env --project-ref dhvyjgzxfsqaminxquuf
# o desde el Dashboard: Project Settings → Edge Functions → Secrets.
#
# NOTA: SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY los inyecta Supabase
# automáticamente; NO hace falta configurarlos.

# ============================================================
# GENERACIÓN DE IMÁGENES · selección de proveedor
# ============================================================
# Proveedor principal: 'google' (default) | 'openai'
IMAGE_PROVIDER=google
# Backend de Google: 'aistudio' (default) | 'vertex'  ← cambia esto para migrar a Vertex
GOOGLE_BACKEND=aistudio
# Respaldo automático a OpenAI si el principal falla o tarda demasiado
ENABLE_OPENAI_FALLBACK=true
# Tiempo máx. (ms) antes de abortar el principal y pasar al respaldo
IMAGE_PROVIDER_TIMEOUT_MS=90000

# --- Modelos (Nano Banana 2 por defecto; configurables) ---
GOOGLE_AI_MODEL=gemini-3.1-flash-image
GOOGLE_VERTEX_MODEL=gemini-3.1-flash-image
OPENAI_IMAGE_MODEL=gpt-image-1

# ============================================================
# CREDENCIALES
# ============================================================
# --- Google AI Studio (PRINCIPAL) — requiere API key de pago ---
GOOGLE_AI_API_KEY=AIza...tu_key_de_google_ai_studio

# --- OpenAI (RESPALDO) — key general; org verificada para gpt-image-1 ---
OPENAI_API_KEY=sk-...tu_key_de_openai

# --- Vertex AI (solo si GOOGLE_BACKEND=vertex) ---
# VERTEX_PROJECT_ID=mi-proyecto-gcp
# VERTEX_LOCATION=global
# Pega el JSON completo de la service account (una sola línea) como valor:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...", ...}

# ============================================================
# EVENTO / MÉTRICAS
# ============================================================
# Nombre del evento o campaña (segmenta las métricas por evento)
EVENT_NAME=demo

# ============================================================
# COPIA OCULTA (opcional)
# ============================================================
# Si se define, cada correo enviado al invitado lleva una copia oculta (BCC)
# a esta dirección, para verificar entregas. Vaciar para desactivar.
EMAIL_BCC=copia-oculta@ejemplo.com

# ============================================================
# SMTP (envío de correo) — rellena con tus datos reales en `.env`, NO aquí
# ============================================================
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=465
SMTP_USER=tu-cuenta@tudominio.com
SMTP_PASS=CAMBIA_ESTO
SMTP_FROM=tu-cuenta@tudominio.com
SMTP_FROM_NAME=SNAPP
